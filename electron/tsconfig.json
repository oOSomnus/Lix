{
  "compilerOptions": {
    "outDir": "../dist-electron",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true
  },
  "include": [
    "*",
    "ipc/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}